# Bu dosyayı .env.local olarak kopyala ve gerçek değerlerini gir (yerel geliştirme için).
# Vercel'de deploy ederken bunları Settings > Environment Variables üzerinden eklersin.

# (İsteğe bağlı) Otomatik günlük takip için — Vercel Storage > KV oluşturunca otomatik eklenir
KV_REST_API_URL=
KV_REST_API_TOKEN=

# (İsteğe bağlı) AI destekli yorum özeti ve başlık önerisi için
# Ücretsiz key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (Otomatik) Vercel Cron tarafından otomatik sağlanır, manuel girmene gerek yok
CRON_SECRET=
