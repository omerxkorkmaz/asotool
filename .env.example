# ASO Tool — Environment Variables
# Copy to .env.local for local development.
# On Vercel: Settings > Environment Variables

# ── Upstash Redis (optional) ─────────────────────────────────────────────
# Required for: Keyword tracking, ranking trend, rate limiting cache
# Vercel: Storage > Create Database > Upstash (Redis) — auto-injected on connect
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternative Upstash env names (also supported by @upstash/redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Gemini (optional) ────────────────────────────────────────────────────
# Free key: https://aistudio.google.com/apikey
# Vercel: Settings → Environment Variables → Production + Preview + Development
GEMINI_API_KEY=

# Model adı (tüm AI özellikleri)
# Güncel önerilen: gemini-3.5-flash
# Alternatifler: gemini-2.5-flash | gemini-2.5-flash-lite
# NOT: gemini-2.5-pro ücretsiz planda kotası 0 olabilir
GEMINI_MODEL=gemini-3.5-flash

# Yoğunluk/kota durumunda yedek model (503 hatasında otomatik denenir)
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Deep Report için ayrı model (boş bırakılırsa GEMINI_MODEL kullanılır)
# GEMINI_DEEP_REPORT_MODEL=gemini-3.5-flash

# ── Vercel Cron (automatic) ──────────────────────────────────────────────
# Set automatically by Vercel when cron jobs are enabled — do not set manually
CRON_SECRET=

# ── Supabase (historical metrics) ─────────────────────────────────────────
# Vercel: Storage → Supabase → Connect Project (otomatik env enjekte edilir)
#
# Bu projenin kullandığı değişkenler (sunucu tarafı — service role):
#   SUPABASE_URL                    → Project URL
#   SUPABASE_SERVICE_ROLE_KEY       → service_role key (tercih edilen)
#   SUPABASE_SECRET_KEY             → alternatif (Vercel entegrasyonu bazen bunu kullanır)
#
# Vercel'in otomatik eklediği ama BU PROJEDE KULLANILMAYAN değişkenler:
#   SUPABASE_ANON_KEY, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY  → istemci (public)
#   POSTGRES_*, POSTGRES_URL, POSTGRES_PRISMA_URL, ...       → doğrudan Postgres (Prisma vb.)
#   SUPABASE_JWT_SECRET                                        → auth JWT
#
# Migration: Supabase Dashboard → SQL Editor → supabase/migrations/001_initial.sql
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=   # SERVICE_ROLE_KEY yoksa Vercel entegrasyonu bunu sağlayabilir

# ── Daily metrics tracking (cron) ─────────────────────────────────────────
# Format: platform:appId (virgülle ayrılmış)
# Android örneği: android:com.example.app
# iOS örneği: ios:1234567890 (App Store ID)
TRACKED_APPS=android:com.example.app,ios:1234567890

# Anahtar kelimeler (virgülle ayrılmış — tüm takip edilen uygulamalara uygulanır)
TRACKED_KEYWORDS=keyword1,keyword2,keyword3

# Keyword arama derinliği (Android max 250, iOS max 800 — Play Store limitleri)
KEYWORD_SEARCH_DEPTH=250

# ── External Signals (Deep Competitor Report) ─────────────────────────────
# Gemini API (yukarıda — web mention taraması)
# YouTube Data API v3 (free: 10,000 units/day)
# Get from: Google Cloud Console → YouTube Data API v3 → Create API Key
YOUTUBE_API_KEY=your-youtube-api-key

# Meta Ad Library (OPTIONAL - system works without it)
# Get from: Facebook Developers → Graph API Explorer → Access Token
# META_ACCESS_TOKEN=your-meta-access-token
